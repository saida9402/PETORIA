# ─────────────────────────────────────────────────────────────────────────────
# Petoria Frontend — Production Environment Variables
#
# Copy this file:
#   cp .env.production.example .env.production
# Then fill in every value marked ⚠ REQUIRED before deploying.
#
# IMPORTANT — two categories of variables:
#
#   NEXT_PUBLIC_*   Baked into the JS bundle at BUILD TIME by `next build`.
#                   Changing these requires rebuilding and redeploying the
#                   Docker image.  Do NOT put secrets here — they are visible
#                   in the browser.
#
#   (no prefix)     Runtime secrets read by the Node.js server process only.
#                   Safe to change without a rebuild; restart the container.
#                   Never appears in the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────


# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the NestJS backend.  No trailing slash.
# ⚠ REQUIRED
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Full GraphQL endpoint.  Normally NEXT_PUBLIC_API_URL + /graphql.
# ⚠ REQUIRED
NEXT_PUBLIC_API_GRAPHQL_URL=https://api.your-domain.com/graphql

# WebSocket endpoint for GraphQL subscriptions.
# MUST use wss:// (secure) when the site is served over HTTPS.
# Using ws:// on an HTTPS page causes a browser mixed-content block.
# ⚠ REQUIRED
NEXT_PUBLIC_API_WS=wss://api.your-domain.com


# ── AI Chat (Claude assistant) ────────────────────────────────────────────────
# Server-side Anthropic API key.  NOT prefixed with NEXT_PUBLIC_ — never
# reaches the browser bundle.  Required only if the AI chat feature is active.
# Leave empty to disable AI chat.
ANTHROPIC_API_KEY=


# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Free API key — https://openweathermap.org/api (Current Weather Data plan).
# Leave empty to silently disable the weather bar.
NEXT_PUBLIC_OPENWEATHER_API_KEY=


# ── Weather fallback location ─────────────────────────────────────────────────
# Shown when the browser denies geolocation AND IP lookup fails.
# Defaults to Hanam-si, South Korea — change to your deployment region.
NEXT_PUBLIC_WEATHER_FALLBACK_LAT=37.5385
NEXT_PUBLIC_WEATHER_FALLBACK_LNG=127.2153
NEXT_PUBLIC_WEATHER_FALLBACK_CITY=Hanam-si
